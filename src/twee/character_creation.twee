:: CharacterCreationName
<div class="creation-container">
    <h2>Identify Yourself</h2>
    <div class="input-group">
        <label for="textbox-playername">What is your name, survivor?</label>
        <<textbox "$playerName" "Survivor">>
    </div>
    <br>
    <<button "Confirm Name" "CharacterCreationTraits">><</button>>
</div>
